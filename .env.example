# ─────────────────────────────────────────────────────────────────────────────
# RouteConnect Logistiek — environment template
#
# Copy this file to `.env` (not committed) and fill in values.
# Only non-sensitive runtime config goes here — SECRETS (Client Secret, Refresh
# Token) MUST be stored in the OS keyring via the Rust side, not in .env.
# Anything in .env ends up readable in the installed app bundle.
# ─────────────────────────────────────────────────────────────────────────────

# Zoho CRM — not yet active, placeholders for when integration lands.
# Public identifier — safe to commit in principle, but we keep it in .env so
# sandbox/prod switches don't touch the code.
VITE_ZOHO_CLIENT_ID=

# EU datacenter defaults. Override for other regions or for sandbox vs prod.
# Sandbox:    https://sandbox.zohoapis.eu
# Production: https://www.zohoapis.eu
VITE_ZOHO_API_BASE=https://sandbox.zohoapis.eu
VITE_ZOHO_ACCOUNTS_URL=https://accounts.zoho.eu

# Custom module API name (confirm exact name in your Zoho setup).
VITE_ZOHO_MODULE=RouteConnectOrders_test

# ─────────────────────────────────────────────────────────────────────────────
# DO NOT PUT HERE:
#   ZOHO_CLIENT_SECRET       → OS keyring (tauri-plugin-stronghold / keyring)
#   ZOHO_REFRESH_TOKEN       → OS keyring
#   Access token             → in-memory only, never persisted
# ─────────────────────────────────────────────────────────────────────────────
