{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Logistiek Allsetra",
  "version": "0.3.0",
  "identifier": "nl.allsetra.routeconnect-logistiek",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Logistiek Allsetra",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Allsetra logistiek werkomgeving",
    "longDescription": "Interne tool voor het Allsetra logistiek team — RouteConnect trackers, accessoires, fietsbeveiliging en sensors prepen en verzenden, plus voorraadbeheer.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFERUEyMjE3NzE3QjFBQTQKUldTa0dudHhGeUxxclF6VFZsZU9RRkc2bEdHZTdYK1piaEc0d0JyVnE0K29DdkNSdmZ1RjBsZUEK",
      "endpoints": [
        "https://github.com/YaroslavSavchenk/allsetra-logistic/releases/latest/download/latest.json"
      ]
    }
  }
}
